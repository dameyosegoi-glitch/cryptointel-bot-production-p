# Telegram bot token from BotFather. Required.
TELEGRAM_BOT_TOKEN=

# CookMyBots AI Gateway base URL. Required for AI synthesis.
# Use the base URL only. Do not include /chat.
COOKMYBOTS_AI_ENDPOINT=https://api.cookmybots.com/api/ai

# CookMyBots AI Gateway key. Required for AI synthesis.
COOKMYBOTS_AI_KEY=

# Optional OpenSea key. NFT features degrade gracefully if missing.
OPENSEA_API_KEY=

# Optional controls with safe defaults.
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2
CONCURRENCY=20
GLOBAL_AI_CAP=1
EXTERNAL_TIMEOUT_MS=20000
